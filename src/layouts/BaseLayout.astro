---
// Font self-hosted via Fontsource — migrati qui dalla sonda index.astro.
import "@fontsource/space-grotesk/400.css";
import "@fontsource/space-grotesk/500.css";
import "@fontsource/space-grotesk/600.css";
import "@fontsource/space-grotesk/700.css";
import "@fontsource/jetbrains-mono/400.css";
import "@fontsource/jetbrains-mono/500.css";
import "@fontsource/source-serif-4/400-italic.css";
import "../styles/global.css";

// URL hashato del woff2 LCP-critical (headline hero in Space Grotesk 500).
// Vite dedupe: stesso asset referenziato da 500.css → il preload combacia.
import sg500 from "@fontsource/space-grotesk/files/space-grotesk-latin-500-normal.woff2?url";

import { getLangFromUrl, useTranslations } from "../i18n/utils";
import Nav from "../components/Nav.astro";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

interface Props {
  title?: string;
  description?: string;
  hrefIt?: string;
  hrefEn?: string;
  breadcrumb?: { name: string; path: string }[];
}

const {
  title = t("meta.title"),
  description = t("meta.description"),
  hrefIt = "/",
  hrefEn = "/en/",
  breadcrumb,
} = Astro.props;

// Canonical = href della lingua corrente, NORMALIZZATO con trailing slash.
// Cloudflare Pages (output 'directory') serve la forma CON slash come 200 e
// 308-redirige quella senza. Sitemap e pagina 200 usano lo slash: canonical,
// hreflang e og:url devono combaciare, altrimenti puntano a un redirect.
const withSlash = (p: string): string => (p.endsWith("/") ? p : p + "/");
const canonicalPath = lang === "en" ? hrefEn : hrefIt;
const canonicalUrl = new URL(withSlash(canonicalPath), Astro.site).href;
const hrefItAbs = new URL(withSlash(hrefIt), Astro.site).href;
const hrefEnAbs = new URL(withSlash(hrefEn), Astro.site).href;

// JSON-LD site-wide: solo nodo WebSite. L'entita' azienda vive nel Footer
// come #localbusiness (LocalBusiness NAP-driven, fonte unica); il publisher
// del WebSite fa cross-ref al #localbusiness via @id.
const siteBase = Astro.site?.href.replace(/\/$/, "") ?? "https://brixiatech.com";
const structuredData = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": siteBase + "/#website",
  "url": siteBase,
  "name": "BrixiaTech",
  "inLanguage": ["it", "en"],
  "publisher": { "@id": siteBase + "/#localbusiness" },
};

// BreadcrumbList per-pagina: compilato da una traccia leggera {name, path}.
// URL assoluti via withSlash + Astro.site (stessa logica del canonical). Null se assente.
const breadcrumbLd =
  breadcrumb && breadcrumb.length
    ? {
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        itemListElement: breadcrumb.map((step, i) => ({
          "@type": "ListItem",
          position: i + 1,
          name: step.name,
          item: new URL(withSlash(step.path), Astro.site).href,
        })),
      }
    : null;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#050B1A" />

    <!-- Canonical + hreflang ad URL assoluti (site = https://brixiatech.com).
         canonicalUrl/hrefItAbs/hrefEnAbs derivati nel frontmatter da
         new URL(path, Astro.site).href; il path e' quello della lingua. -->
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang="it" href={hrefItAbs} />
    <link rel="alternate" hreflang="en" href={hrefEnAbs} />
    <link rel="alternate" hreflang="x-default" href={hrefItAbs} />

    <!-- Preload font LCP-critical: headline hero in Space Grotesk 500 -->
    <link rel="preload" href={sg500} as="font" type="font/woff2" crossorigin />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:locale" content={t("meta.ogLocale")} />
    <meta property="og:site_name" content="BrixiaTech" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />

    <!-- JSON-LD: WebSite site-wide; entita' azienda nel Footer (#localbusiness) -->
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
    {breadcrumbLd && <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />}
  </head>
  <body>
    <div class="grain" aria-hidden="true"></div>
    <Nav hrefIt={hrefIt} hrefEn={hrefEn} />
    <slot />
  </body>
</html>
