---
// Font self-hosted via Fontsource — migrati qui dalla sonda index.astro.
import "@fontsource/space-grotesk/400.css";
import "@fontsource/space-grotesk/500.css";
import "@fontsource/space-grotesk/600.css";
import "@fontsource/space-grotesk/700.css";
import "@fontsource/jetbrains-mono/400.css";
import "@fontsource/jetbrains-mono/500.css";
import "@fontsource/source-serif-4/400-italic.css";
import "../styles/global.css";

// URL hashato del woff2 LCP-critical (headline hero in Space Grotesk 500).
// Vite dedupe: stesso asset referenziato da 500.css → il preload combacia.
import sg500 from "@fontsource/space-grotesk/files/space-grotesk-latin-500-normal.woff2?url";

import { getLangFromUrl, useTranslations } from "../i18n/utils";
import Nav from "../components/Nav.astro";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

interface Props {
  title?: string;
  description?: string;
  hrefIt?: string;
  hrefEn?: string;
}

const {
  title = t("meta.title"),
  description = t("meta.description"),
  hrefIt = "/",
  hrefEn = "/en/",
} = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#050B1A" />

    <!-- Canonical + hreflang (path relativi).
         TODO STEP 8 — con `site` definito, passare canonical e hreflang a
         URL assoluti via new URL(path, Astro.site).href -->
    <link rel="canonical" href={Astro.url.pathname} />
    <link rel="alternate" hreflang="it" href={hrefIt} />
    <link rel="alternate" hreflang="en" href={hrefEn} />
    <link rel="alternate" hreflang="x-default" href={hrefIt} />

    <!-- Preload font LCP-critical: headline hero in Space Grotesk 500 -->
    <link rel="preload" href={sg500} as="font" type="font/woff2" crossorigin />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:locale" content={t("meta.ogLocale")} />
    <meta property="og:site_name" content="BrixiaTech" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
  </head>
  <body>
    <div class="grain" aria-hidden="true"></div>
    <Nav hrefIt={hrefIt} hrefEn={hrefEn} />
    <slot />
  </body>
</html>
