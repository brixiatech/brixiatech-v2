---
// Applications.astro — sezione #6 homepage, griglia 4 scenari applicativi per settore.
// 4 scenari (office/architecture/institutional/hospitality), no card, layout editoriale.
// ZERO JS. Token --c-*. Reduced-motion + responsive coerenti con ClientsStrip.
// Icone SVG inline (stroke currentColor, colore da --c-cyan). i18n via apps.* keys.

import { getLangFromUrl, useTranslations } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const scenarios = [
  {
    icon: '<rect x="4" y="3" width="16" height="18" rx="1"/><line x1="4" y1="9" x2="20" y2="9"/><line x1="12" y1="3" x2="12" y2="21"/>',
    titleKey: 'apps.office.title',
    bodyKey: 'apps.office.body',
  },
  {
    icon: '<rect x="3" y="3" width="18" height="18" rx="1"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="3" y1="15" x2="21" y2="15"/><line x1="9" y1="3" x2="9" y2="21"/><line x1="15" y1="3" x2="15" y2="21"/>',
    titleKey: 'apps.architecture.title',
    bodyKey: 'apps.architecture.body',
  },
  {
    icon: '<line x1="3" y1="21" x2="21" y2="21"/><line x1="4" y1="21" x2="4" y2="10"/><line x1="20" y1="21" x2="20" y2="10"/><line x1="8" y1="21" x2="8" y2="10"/><line x1="16" y1="21" x2="16" y2="10"/><line x1="12" y1="21" x2="12" y2="10"/><path d="M3 10 L12 3 L21 10 Z"/>',
    titleKey: 'apps.institutional.title',
    bodyKey: 'apps.institutional.body',
  },
  {
    icon: '<path d="M3 18 L3 10 L21 10 L21 18"/><line x1="3" y1="14" x2="21" y2="14"/><line x1="3" y1="18" x2="3" y2="20"/><line x1="21" y1="18" x2="21" y2="20"/>',
    titleKey: 'apps.hospitality.title',
    bodyKey: 'apps.hospitality.body',
  },
] as const;
---

<section class="apps" aria-labelledby="apps-eyebrow">
  <p class="apps__eyebrow" id="apps-eyebrow">{t('apps.eyebrow')}</p>
  <h2 class="apps__title">{t('apps.title')}</h2>
  <p class="apps__intro">{t('apps.intro')}</p>

  <div class="apps__grid">
    {scenarios.map((s) => (
      <article class="apps__item">
        <div class="apps__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" set:html={s.icon} />
        </div>
        <h3 class="apps__item-title">{t(s.titleKey)}</h3>
        <p class="apps__item-body">{t(s.bodyKey)}</p>
      </article>
    ))}
  </div>
</section>

<style>
  .apps {
    padding: var(--space-section-y) var(--space-section-x);
    border-top: 1px solid var(--border-hairline);
  }

  .apps__eyebrow {
    text-align: center;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    color: var(--c-mist-bright);
    margin: 0 0 24px;
  }

  .apps__title {
    font-family: var(--font-display);
    color: var(--c-pearl);
    text-align: center;
    font-size: clamp(1.6rem, 3vw, 2.4rem);
    line-height: 1.2;
    max-width: 800px;
    margin: 0 auto 24px;
    font-weight: 500;
  }

  .apps__intro {
    color: var(--c-mist);
    text-align: center;
    max-width: 680px;
    margin: 0 auto 64px;
    line-height: 1.6;
    font-size: 1rem;
  }

  .apps__grid {
    max-width: var(--container-max);
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 48px 40px;
  }

  .apps__item {
    text-align: left;
  }

  .apps__icon {
    color: var(--c-cyan);
    margin-bottom: 20px;
  }

  .apps__icon svg {
    width: 32px;
    height: 32px;
    display: block;
  }

  .apps__item-title {
    font-family: var(--font-display);
    color: var(--c-pearl);
    font-size: 1.05rem;
    font-weight: 500;
    margin: 0 0 12px;
    line-height: 1.3;
  }

  .apps__item-body {
    color: var(--c-mist);
    font-size: 0.92rem;
    line-height: 1.6;
    margin: 0;
  }

  /* Nessuna transition/animazione in questo componente → nulla da neutralizzare.
     Blocco mantenuto per coerenza con ClientsStrip (reduced-motion ready). */
  @media (prefers-reduced-motion: reduce) {
    /* no-op */
  }

  @media (max-width: 900px) {
    .apps {
      padding: 56px 24px;
    }
    .apps__intro {
      margin-bottom: 48px;
    }
    .apps__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 40px 32px;
    }
  }

  @media (max-width: 560px) {
    .apps__grid {
      grid-template-columns: 1fr;
      gap: 36px;
    }
  }
</style>
