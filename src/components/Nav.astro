---
// Nav statico, zero JS. Portato da brixiatech-hero-v1.html.
// Menu mobile: checkbox-hack (input nascosto + label burger + :checked).
// Scelta rispetto a <details>: con details il browser nasconde nativamente il
// contenuto chiuso su un asse che display non governa -> menu invisibile anche
// su desktop. Con la checkbox ogni show/hide e' regola CSS d'autore, nessuno
// user-agent stylesheet di mezzo. Verificato a runtime.
// FIX #4: niente mix-blend-mode (illeggibile/flicker su skyline). Colore fisso
// pearl + scrim gradiente sottile come backdrop difensivo.
import { getLangFromUrl, useTranslations } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// Coppia IT/EN della pagina corrente, inoltrata dal BaseLayout (stessa fonte
// degli hreflang). Lo switcher punta alla versione nell'altra lingua DELLA
// PAGINA CORRENTE, non alla home.
interface Props {
  hrefIt?: string;
  hrefEn?: string;
}
const { hrefIt = "/", hrefEn = "/en/" } = Astro.props;

// Voci nav path-aware: da qualsiasi pagina riportano alla home + ancora,
// nella lingua corrente. Ancore = id reali degli eyebrow di sezione.
const base = lang === 'en' ? '/en/' : '/';
---

<nav class="nav">
  <a class="nav__logo" href={base} aria-label={t('nav.home')}>BRIXIATECH</a>

  {/* Checkbox-hack: input governa lo stato aperto/chiuso del menu mobile.
      Nascosto visivamente ma raggiungibile via label (burger). */}
  <input type="checkbox" id="nav-toggle" class="nav__toggle" aria-hidden="true" />

  <label for="nav-toggle" class="nav__burger" aria-label="Menu">
    <span class="nav__burger-box">
      <span class="nav__burger-line"></span>
      <span class="nav__burger-line"></span>
      <span class="nav__burger-line"></span>
    </span>
  </label>

  <ul class="nav__menu">
    <li><a href={`${base}#tech-eyebrow`}>{t('nav.tech')}</a></li>
    <li><a href={`${base}#blogic-eyebrow`}>B-LOGIC</a></li>
    {/* <li><a href={`${base}#realizzazioni-eyebrow`}>{t('nav.work')}</a></li> */}
    <li><a href={`${base}insights`}>{t('nav.insights')}</a></li>
    <li><a href="https://blogic.brixiatech.com/api/login.php" target="_blank" rel="noopener noreferrer">Dashboard</a></li>
  </ul>

  <div class="nav__actions">
    <a href={`${base}#contact-eyebrow`} class="nav__cta">{t('nav.quote')}</a>

    <div class="nav__lang" aria-label={t('lang.switch')}>
      <a href={hrefIt} class="nav__lang-link" aria-current={lang === 'it' ? 'true' : undefined}>IT</a>
      <span class="nav__lang-sep" aria-hidden="true">|</span>
      <a href={hrefEn} class="nav__lang-link" aria-current={lang === 'en' ? 'true' : undefined}>EN</a>
    </div>
  </div>
</nav>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    padding: 24px 48px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    z-index: 100;
    /* FIX #4: niente mix-blend-mode. Scrim difensivo per leggibilita'. */
    background: linear-gradient(
      180deg,
      rgba(5, 5, 7, 0.55) 0%,
      rgba(5, 5, 7, 0) 100%
    );
  }

  .nav__logo {
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 0.08em;
    color: var(--c-pearl);
    text-decoration: none;
    transition: opacity 200ms var(--ease);
  }

  .nav__logo:hover {
    opacity: 0.7;
  }

  .nav__logo:focus-visible {
    outline: 2px solid var(--c-cyan);
    outline-offset: 3px;
  }

  /* Input di controllo del menu mobile: fuori dal flusso visivo, ma non
     display:none (deve restare targettabile dalla label e reattivo a :checked). */
  .nav__toggle {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    opacity: 0;
    -webkit-appearance: none;
    appearance: none;
    pointer-events: none;
  }

  /* Burger: nascosto su desktop, compare sotto 900px via media query. */
  .nav__burger {
    display: none;
    cursor: pointer;
    padding: 4px;
    align-items: center;
  }

  .nav__burger-box {
    display: flex;
    flex-direction: column;
    gap: 5px;
    width: 22px;
  }

  .nav__burger-line {
    height: 2px;
    width: 100%;
    background: var(--c-pearl);
    border-radius: 2px;
    transition: transform 200ms var(--ease), opacity 200ms var(--ease);
  }

  /* Focus visibile sul burger quando l'input riceve focus da tastiera. */
  .nav__toggle:focus-visible + .nav__burger {
    outline: 2px solid var(--c-cyan);
    outline-offset: 3px;
    border-radius: 4px;
  }

  /* Stato aperto: le tre linee diventano una X. */
  .nav__toggle:checked + .nav__burger .nav__burger-line:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .nav__toggle:checked + .nav__burger .nav__burger-line:nth-child(2) {
    opacity: 0;
  }
  .nav__toggle:checked + .nav__burger .nav__burger-line:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  .nav__menu {
    display: flex;
    gap: 32px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav__menu a {
    font-size: 13px;
    color: var(--c-pearl);
    text-decoration: none;
    opacity: 0.7;
    transition: opacity 200ms var(--ease);
  }

  .nav__menu a:hover {
    opacity: 1;
  }

  .nav__cta {
    font-size: 13px;
    color: var(--c-pearl);
    text-decoration: none;
    border: 1px solid rgba(245, 245, 247, 0.3);
    padding: 8px 16px;
    border-radius: var(--radius-pill);
    transition: all 200ms var(--ease);
  }

  .nav__cta:hover {
    border-color: var(--c-pearl);
    background: rgba(245, 245, 247, 0.06);
  }

  /* Language switcher: fuori da .nav__menu cosi' resta visibile sotto 900px. */
  .nav__lang {
    display: flex;
    gap: 8px;
    align-items: center;
  }

  .nav__lang-link {
    font-size: 13px;
    color: var(--c-pearl);
    text-decoration: none;
    opacity: 0.7;
    transition: opacity 200ms var(--ease);
  }

  .nav__lang-link:hover {
    opacity: 1;
  }

  .nav__lang-link[aria-current="true"] {
    opacity: 1;
    font-weight: 500;
  }

  /* Focus coerente: outline cyan come GlassDemo (unico precedente interattivo). */
  .nav__lang-link:focus-visible {
    outline: 2px solid var(--c-cyan);
    outline-offset: 3px;
  }

  .nav__lang-sep {
    color: var(--c-pearl);
    opacity: 0.3;
  }

  /* Raggruppa CTA + switcher a destra. */
  .nav__actions {
    display: flex;
    align-items: center;
    gap: 24px;
  }

  @media (max-width: 900px) {
    .nav {
      padding: 20px 24px;
    }

    /* Ordine su mobile: logo (1, default) | actions (2) | burger (3, estrema destra). */
    .nav__actions { order: 2; gap: 16px; }
    .nav__burger { order: 3; display: flex; }

    /* Menu voci -> pannello a tendina sotto la barra, chiuso di default. */
    .nav__menu {
      display: none;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      flex-direction: column;
      gap: 0;
      padding: 4px 24px 16px;
      background: rgba(5, 5, 7, 0.97);
      border-top: 1px solid rgba(245, 245, 247, 0.08);
      box-shadow: 0 12px 32px rgba(0, 0, 0, 0.35);
    }

    /* Aperto: la checkbox spunta -> il pannello scende.
       .nav__menu e' sibling successivo dell'input nel DOM. */
    .nav__toggle:checked ~ .nav__menu {
      display: flex;
    }

    .nav__menu li {
      border-top: 1px solid rgba(245, 245, 247, 0.06);
    }
    .nav__menu li:first-child {
      border-top: none;
    }

    .nav__menu a {
      display: block;
      padding: 14px 0;
      font-size: 15px;
      opacity: 0.85;
    }
  }
</style>
