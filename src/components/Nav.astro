---
// Nav con collasso a burger oltre soglia di scroll (~120px) - rev 2.1.
// (2.1: da collassato lo switcher lingua collassa anche in larghezza ->
//  il gruppo CTA+burger chiude a filo del padding destro, 48px, simmetrico
//  al logo. Prima lo switcher invisibile teneva lo spazio e disallineava.)
// - Espansa (top di pagina, desktop): logo | voci | CTA + IT/EN. Trasparente.
// - Collassata (scroll > 120px): le voci SCIVOLANO verso destra (slide 64px +
//   dissolvenza, 300ms) in direzione della pillola Preventivo; il burger
//   emerge con un ritardo di 120ms accanto alla CTA, arrivando dalla stessa
//   direzione del movimento. La CTA "Preventivo" RESTA SEMPRE in barra
//   (mai nel pannello); lo switcher lingua sfuma e passa nel pannello.
// - Pannello: su desktop e' un dropdown COMPATTO ancorato a destra
//   (240px, angoli arrotondati); su mobile resta full-width come prima.
// - Mobile (<900px): burger sempre in barra (ultimo, dentro le actions);
//   oltre soglia sfuma solo lo switcher lingua, la CTA resta.
// Meccanica apertura menu: checkbox-hack (input nascosto + label burger +
// :checked). La label vive dentro .nav__actions -> i selettori usano
// `~ .nav__actions .nav__burger` (sibling generale + discendente).
// JS minimo invariato: driver scroll rAF-throttled che alterna
// .nav--collapsed e richiude il pannello quando si rientra sopra soglia.
// Senza JS la nav resta espansa (progressive enhancement).
// Guardia prefers-reduced-motion -> switch istantaneo, nessuno slide.
// FIX #4 invariato: niente mix-blend-mode; colore fisso pearl.
import { getLangFromUrl, useTranslations } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// Coppia IT/EN della pagina corrente, inoltrata dal BaseLayout (stessa fonte
// degli hreflang). Lo switcher punta alla versione nell'altra lingua DELLA
// PAGINA CORRENTE, non alla home.
interface Props {
  hrefIt?: string;
  hrefEn?: string;
}
const { hrefIt = "/", hrefEn = "/en/" } = Astro.props;

// Voci nav path-aware: da qualsiasi pagina riportano alla home + ancora,
// nella lingua corrente. Ancore = id reali degli eyebrow di sezione.
// NB: la CTA della nav resta cross-page verso la home (decisione v42:
// su privacy/404 un bare fragment sarebbe un'ancora morta).
const base = lang === 'en' ? '/en/' : '/';
---

<nav class="nav">
  <a class="nav__logo" href={base} aria-label={t('nav.home')}>BRIXIATECH</a>

  {/* Checkbox-hack: input governa lo stato aperto/chiuso del pannello.
      Nascosto visivamente ma raggiungibile via label (burger). */}
  <input type="checkbox" id="nav-toggle" class="nav__toggle" aria-hidden="true" />

  {/* Riga voci: solo desktop espanso. Da collassato scivola verso destra
      e sfuma; le voci vivono poi nel pannello (.nav__panel). */}
  <ul class="nav__menu">
    <li><a href={`${base}#tech-eyebrow`}>{t('nav.tech')}</a></li>
    <li><a href={`${base}#blogic-eyebrow`}>B-logic</a></li>
    {/* <li><a href={`${base}#realizzazioni-eyebrow`}>{t('nav.work')}</a></li> */}
    <li><a href={`${base}insights/`}>{t('nav.insights')}</a></li>
    <li><a href="https://blogic.brixiatech.com/api/login.php" target="_blank" rel="noopener noreferrer">Dashboard</a></li>
  </ul>

  {/* Actions: CTA sempre visibile; lingua sfuma da collassato; il burger
      (label) e' assoluto a sinistra della CTA e appare solo da collassato. */}
  <div class="nav__actions">
    <a href={`${base}#contact-eyebrow`} class="nav__cta">{t('nav.quote')}</a>

    <div class="nav__lang" aria-label={t('lang.switch')}>
      <a href={hrefIt} class="nav__lang-link" aria-current={lang === 'it' ? 'true' : undefined}>IT</a>
      <span class="nav__lang-sep" aria-hidden="true">|</span>
      <a href={hrefEn} class="nav__lang-link" aria-current={lang === 'en' ? 'true' : undefined}>EN</a>
    </div>

    <label for="nav-toggle" class="nav__burger" aria-label="Menu">
      <span class="nav__burger-box">
        <span class="nav__burger-line"></span>
        <span class="nav__burger-line"></span>
        <span class="nav__burger-line"></span>
      </span>
    </label>
  </div>

  {/* Pannello: voci sempre; switcher lingua solo da collassato
      (.nav__panel-extra). La CTA NON entra mai nel pannello: resta in barra. */}
  <ul class="nav__panel">
    <li><a href={`${base}#tech-eyebrow`}>{t('nav.tech')}</a></li>
    <li><a href={`${base}#blogic-eyebrow`}>B-logic</a></li>
    {/* <li><a href={`${base}#realizzazioni-eyebrow`}>{t('nav.work')}</a></li> */}
    <li><a href={`${base}insights/`}>{t('nav.insights')}</a></li>
    <li><a href="https://blogic.brixiatech.com/api/login.php" target="_blank" rel="noopener noreferrer">Dashboard</a></li>
    <li class="nav__panel-extra">
      <div class="nav__panel-lang" aria-label={t('lang.switch')}>
        <a href={hrefIt} class="nav__lang-link" aria-current={lang === 'it' ? 'true' : undefined}>IT</a>
        <span class="nav__lang-sep" aria-hidden="true">|</span>
        <a href={hrefEn} class="nav__lang-link" aria-current={lang === 'en' ? 'true' : undefined}>EN</a>
      </div>
    </li>
  </ul>
</nav>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    padding: 24px 48px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    z-index: 100;
    /* Barra completamente trasparente: nessuno scrim, nessun blur.
       Il trade-off storico (voci sopra i testi allo scroll) e' risolto
       dal collasso a burger oltre soglia, non da uno sfondo. */
    background: transparent;
  }

  .nav__logo {
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 0.08em;
    color: var(--c-pearl);
    text-decoration: none;
    transition: opacity 200ms var(--ease);
  }

  .nav__logo:hover {
    opacity: 0.7;
  }

  .nav__logo:focus-visible {
    outline: 2px solid var(--c-cyan);
    outline-offset: 3px;
  }

  /* Input di controllo del pannello: fuori dal flusso visivo, ma non
     display:none (deve restare targettabile dalla label e reattivo a :checked). */
  .nav__toggle {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    opacity: 0;
    -webkit-appearance: none;
    appearance: none;
    pointer-events: none;
  }

  /* Riga voci desktop. Da collassato: slide verso destra (in direzione
     della CTA) + dissolvenza, 300ms; poi fuori dall'accessibility tree
     (visibility) e dal puntatore. Occupa comunque spazio (niente
     display:none) cosi' il layout non salta. */
  .nav__menu {
    display: flex;
    gap: 32px;
    list-style: none;
    margin: 0;
    padding: 0;
    transition: opacity 300ms var(--ease), transform 300ms var(--ease), visibility 0s 0s;
  }

  .nav--collapsed .nav__menu {
    opacity: 0;
    transform: translateX(64px);
    visibility: hidden;
    pointer-events: none;
    transition: opacity 300ms var(--ease), transform 300ms var(--ease), visibility 0s 300ms;
  }

  .nav__menu a {
    font-size: 13px;
    color: var(--c-pearl);
    text-decoration: none;
    opacity: 0.7;
    transition: opacity 200ms var(--ease);
  }

  .nav__menu a:hover {
    opacity: 1;
  }

  .nav__cta {
    font-size: 13px;
    color: var(--c-pearl);
    text-decoration: none;
    border: 1px solid rgba(245, 245, 247, 0.3);
    padding: 8px 16px;
    border-radius: var(--radius-pill);
    transition: all 200ms var(--ease);
  }

  .nav__cta:hover {
    border-color: var(--c-pearl);
    background: rgba(245, 245, 247, 0.06);
  }

  /* Language switcher in barra: da collassato sfuma E collassa in
     larghezza (max-width + margin-left -> 0), cosi' la CTA scivola a filo
     del padding destro (48px), simmetrica al logo. La versione nel
     pannello prende il suo posto. */
  .nav__lang {
    display: flex;
    gap: 8px;
    align-items: center;
    margin-left: 24px;
    max-width: 120px;
    white-space: nowrap;
    transition: opacity 200ms var(--ease), max-width 300ms var(--ease), margin-left 300ms var(--ease), visibility 0s 0s;
  }

  .nav--collapsed .nav__lang {
    opacity: 0;
    max-width: 0;
    margin-left: 0;
    overflow: hidden;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 200ms var(--ease), max-width 300ms var(--ease), margin-left 300ms var(--ease), visibility 0s 300ms;
  }

  .nav__lang-link {
    font-size: 13px;
    color: var(--c-pearl);
    text-decoration: none;
    opacity: 0.7;
    transition: opacity 200ms var(--ease);
  }

  .nav__lang-link:hover {
    opacity: 1;
  }

  .nav__lang-link[aria-current="true"] {
    opacity: 1;
    font-weight: 500;
  }

  /* Focus coerente: outline cyan come GlassDemo (unico precedente interattivo). */
  .nav__lang-link:focus-visible {
    outline: 2px solid var(--c-cyan);
    outline-offset: 3px;
  }

  .nav__lang-sep {
    color: var(--c-pearl);
    opacity: 0.3;
  }

  /* Raggruppa CTA + switcher a destra. position:relative ancora il burger.
     Niente flex gap: la spaziatura vive nel margin-left dello switcher,
     cosi' collassa insieme alla sua larghezza. */
  .nav__actions {
    position: relative;
    display: flex;
    align-items: center;
  }

  /* Burger: icona nuda, nessuno sfondo. Su desktop e' assoluto a sinistra
     della CTA (right:100% del box actions) ed emerge con delay 120ms
     arrivando dalla direzione dello slide delle voci; su mobile torna
     statico e sempre visibile (media query). */
  .nav__burger {
    position: absolute;
    right: calc(100% + 20px);
    top: 50%;
    display: flex;
    align-items: center;
    cursor: pointer;
    padding: 4px;
    opacity: 0;
    transform: translateY(-50%) translateX(-12px);
    visibility: hidden;
    pointer-events: none;
    transition: opacity 200ms var(--ease), transform 200ms var(--ease), visibility 0s 200ms;
  }

  .nav--collapsed .nav__burger {
    opacity: 1;
    transform: translateY(-50%) translateX(0);
    visibility: visible;
    pointer-events: auto;
    transition: opacity 200ms var(--ease) 120ms, transform 200ms var(--ease) 120ms, visibility 0s 120ms;
  }

  .nav__burger-box {
    display: flex;
    flex-direction: column;
    gap: 5px;
    width: 22px;
  }

  .nav__burger-line {
    height: 2px;
    width: 100%;
    background: var(--c-pearl);
    border-radius: 2px;
    transition: transform 200ms var(--ease), opacity 200ms var(--ease);
  }

  /* Focus visibile sul burger quando l'input riceve focus da tastiera.
     La label vive dentro .nav__actions -> sibling generale + discendente. */
  .nav__toggle:focus-visible ~ .nav__actions .nav__burger {
    outline: 2px solid var(--c-cyan);
    outline-offset: 3px;
    border-radius: 4px;
  }

  /* Stato aperto: le tre linee diventano una X. */
  .nav__toggle:checked ~ .nav__actions .nav__burger .nav__burger-line:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .nav__toggle:checked ~ .nav__actions .nav__burger .nav__burger-line:nth-child(2) {
    opacity: 0;
  }
  .nav__toggle:checked ~ .nav__actions .nav__burger .nav__burger-line:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* Pannello: chiuso di default. Su DESKTOP e' un dropdown compatto
     ancorato a destra sotto il burger, NON full-width (revisione 2 su
     feedback estetico). Su desktop si apre solo da collassato: il gate
     .nav--collapsed lo richiude se si torna in cima con menu aperto. */
  .nav__panel {
    display: none;
    position: absolute;
    top: calc(100% - 10px);
    right: 48px;
    left: auto;
    width: 240px;
    flex-direction: column;
    gap: 0;
    list-style: none;
    margin: 0;
    padding: 6px 20px 10px;
    background: rgba(5, 5, 7, 0.97);
    border: 1px solid rgba(245, 245, 247, 0.08);
    border-radius: 14px;
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.35);
  }

  .nav--collapsed .nav__toggle:checked ~ .nav__panel {
    display: flex;
  }

  .nav__panel li {
    border-top: 1px solid rgba(245, 245, 247, 0.06);
  }
  .nav__panel li:first-child {
    border-top: none;
  }

  .nav__panel a {
    display: block;
    padding: 14px 0;
    font-size: 15px;
    color: var(--c-pearl);
    text-decoration: none;
    opacity: 0.85;
    transition: opacity 200ms var(--ease);
  }

  .nav__panel a:hover {
    opacity: 1;
  }

  /* Voce extra (switcher lingua): esiste solo nello stato collassato.
     Sopra soglia lo switcher e' ancora in barra -> niente doppioni. */
  .nav__panel-extra {
    display: none;
  }

  .nav--collapsed .nav__panel-extra {
    display: block;
  }

  /* Switcher lingua nel pannello: link inline, niente padding a blocco. */
  .nav__panel-lang {
    display: flex;
    gap: 8px;
    align-items: center;
    padding: 14px 0;
  }

  .nav__panel .nav__panel-lang a {
    display: inline;
    padding: 0;
    font-size: 15px;
  }

  @media (max-width: 900px) {
    .nav {
      padding: 20px 24px;
    }

    /* La riga voci desktop non esiste su mobile: le voci stanno nel pannello. */
    .nav__menu {
      display: none;
    }

    /* Burger: torna in flusso dentro le actions (ultimo, estrema destra),
       sempre visibile, nessuno slide. */
    .nav__burger {
      position: static;
      transform: none;
      opacity: 1;
      visibility: visible;
      pointer-events: auto;
      transition: none;
    }

    .nav__lang {
      margin-left: 16px;
      max-width: 120px;
    }

    .nav__burger {
      margin-left: 16px;
    }

    /* Pannello: su mobile torna full-width sotto la barra (approvato). */
    .nav__panel {
      top: 100%;
      left: 0;
      right: 0;
      width: auto;
      border: none;
      border-top: 1px solid rgba(245, 245, 247, 0.08);
      border-radius: 0;
      padding: 4px 24px 16px;
    }

    /* Su mobile il pannello si apre anche sopra soglia (voci base). */
    .nav__toggle:checked ~ .nav__panel {
      display: flex;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .nav__menu,
    .nav__lang,
    .nav__burger,
    .nav__burger-line,
    .nav__panel a {
      transition: none;
    }
  }
</style>

<script>
  // Driver di collasso: oltre NAV_COLLAPSE_Y aggiunge .nav--collapsed alla
  // barra; al rientro sopra soglia richiude anche il pannello (altrimenti
  // su desktop resterebbe :checked con label invisibile). rAF-throttled,
  // listener passive. Chiamata iniziale: copre gli arrivi mid-page da
  // link con ancora (#contact-eyebrow ecc.).
  const NAV_COLLAPSE_Y = 120;
  const nav = document.querySelector(".nav");
  const toggle = document.getElementById("nav-toggle") as HTMLInputElement | null;

  let collapsed = false;
  let ticking = false;

  function update() {
    const c = window.scrollY > NAV_COLLAPSE_Y;
    if (c !== collapsed) {
      collapsed = c;
      nav?.classList.toggle("nav--collapsed", c);
      if (!c && toggle) toggle.checked = false;
    }
    ticking = false;
  }

  window.addEventListener(
    "scroll",
    () => {
      if (!ticking) {
        ticking = true;
        requestAnimationFrame(update);
      }
    },
    { passive: true }
  );

  update();
</script>
