---
// HowItWorks.astro — sezione #4 homepage, come funziona (educazione PDLC, formato AEO).
// 4 coppie domanda/risposta (mechanism / power / control / form), griglia 2×2, no card.
// ZERO JS. Token --c-*. Reduced-motion + responsive coerenti con ProblemSection.
// Nessuna icona (testo Q&A, AEO). i18n via how.* keys.

import { getLangFromUrl, useTranslations } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const qa = [
  {
    titleKey: 'how.mechanism.title',
    bodyKey: 'how.mechanism.body',
  },
  {
    titleKey: 'how.power.title',
    bodyKey: 'how.power.body',
  },
  {
    titleKey: 'how.control.title',
    bodyKey: 'how.control.body',
  },
  {
    titleKey: 'how.form.title',
    bodyKey: 'how.form.body',
  },
] as const;
---

<section class="how" aria-labelledby="how-eyebrow">
  <p class="how__eyebrow" id="how-eyebrow">{t('how.eyebrow')}</p>
  <h2 class="how__title">{t('how.title')}</h2>
  <p class="how__lead">{t('how.lead')}</p>

  <div class="how__grid">
    {qa.map((item) => (
      <article class="how__item">
        <h3 class="how__q">{t(item.titleKey)}</h3>
        <p class="how__a">{t(item.bodyKey)}</p>
      </article>
    ))}
  </div>

  <p class="how__bridge">{t('how.bridge')}</p>
</section>

<style>
  .how {
    padding: var(--space-section-y) var(--space-section-x);
  }

  .how__eyebrow {
    text-align: center;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    color: var(--c-mist-bright);
    margin: 0 0 24px;
  }

  .how__title {
    font-family: var(--font-display);
    color: var(--c-pearl);
    text-align: center;
    font-size: clamp(1.6rem, 3vw, 2.4rem);
    line-height: 1.2;
    max-width: 800px;
    margin: 0 auto 24px;
    font-weight: 500;
  }

  .how__lead {
    color: var(--c-mist);
    text-align: center;
    max-width: 680px;
    margin: 0 auto 64px;
    line-height: 1.6;
    font-size: 1rem;
  }

  .how__grid {
    max-width: var(--container-max);
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 56px 48px;
  }

  .how__item {
    text-align: left;
    border-top: 1px solid var(--border-hairline);
    padding-top: 24px;
  }

  .how__q {
    font-family: var(--font-display);
    color: var(--c-pearl);
    font-size: 1.05rem;
    font-weight: 500;
    margin: 0 0 12px;
    line-height: 1.3;
  }

  .how__a {
    color: var(--c-mist);
    font-size: 0.92rem;
    line-height: 1.6;
    margin: 0;
  }

  .how__bridge {
    color: var(--c-mist);
    text-align: center;
    max-width: 680px;
    margin: 64px auto 0;
    line-height: 1.6;
    font-size: 1rem;
  }

  /* Nessuna transition/animazione in questo componente → nulla da neutralizzare.
     Blocco mantenuto per coerenza con ProblemSection (reduced-motion ready). */
  @media (prefers-reduced-motion: reduce) {
    /* no-op */
  }

  @media (max-width: 900px) {
    .how {
      padding: 56px 24px;
    }
    .how__lead {
      margin-bottom: 48px;
    }
    .how__grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    .how__bridge {
      margin-top: 48px;
    }
  }
</style>
