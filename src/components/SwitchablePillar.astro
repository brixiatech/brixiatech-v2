---
// SwitchablePillar.astro — Pillar bilingue "famiglia switchable": hub editoriale che
// orienta tra le tecnologie (PDLC / PNLC / SPD / EC / Blackout) e linka alle pagine-prodotto.
// Riusa struttura, classi e stile dell'articolo Insight (è editoriale a tutti gli effetti)
// con in piu' un blocco FAQ. lang/t ricavati internamente (mai props).
// Route: EN /en/electrochromic-glass/ · IT /vetro-switchable/. Namespace i18n: pillar.switchable.*
import { getLangFromUrl, useTranslations } from "../i18n/utils";
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// Base URL lang-aware per i link verso la home (prefixDefaultLocale: false).

// Link a pagina-prodotto: i segmenti di path sono tradotti -> const dedicati lang-aware.
const pdlcHref = lang === "en" ? "/en/technologies/smart-film-pdlc/" : "/tecnologie/smart-film-pdlc/";
const pnlcHref = lang === "en" ? "/en/technologies/smart-film-pnlc/" : "/tecnologie/smart-film-pnlc/";
const spdHref = lang === "en" ? "/en/technologies/spd-smart-glass/" : "/tecnologie/spd-smart-glass/";
const ecHref = lang === "en" ? "/en/technologies/ec-smart-glass/" : "/tecnologie/ec-smart-glass/";
const blackoutHref = lang === "en" ? "/en/technologies/blackout-hyper-glass/" : "/tecnologie/blackout-hyper-glass/";
const techHref = lang === "en" ? "/en/technologies/" : "/tecnologie/";

// Blocchi corpo a due colonne. Ogni link = { href, labelKey }. Blocchi narrativi = links vuoto.
type BlockLink = { href: string; labelKey: string };
type Block = { key: string; links: BlockLink[] };
const blocks: Block[] = [
  { key: "frame", links: [] },
  {
    key: "core",
    links: [
      { href: pdlcHref, labelKey: "pillar.switchable.core.pdlc" },
      { href: pnlcHref, labelKey: "pillar.switchable.core.pnlc" },
      { href: blackoutHref, labelKey: "pillar.switchable.core.blackout" },
    ],
  },
  { key: "spd", links: [{ href: spdHref, labelKey: "pillar.switchable.spd.link" }] },
  { key: "ec", links: [{ href: ecHref, labelKey: "pillar.switchable.ec.link" }] },
  { key: "facciate", links: [] },
  { key: "film", links: [{ href: pdlcHref, labelKey: "pillar.switchable.film.link" }] },
  { key: "scegliere", links: [] },
];

// FAQ: 5 coppie Q/A (blocco pronto per schema FAQPage in un giro successivo).
const faqs = [
  { q: "pillar.switchable.faq.q1", a: "pillar.switchable.faq.a1" },
  { q: "pillar.switchable.faq.q2", a: "pillar.switchable.faq.a2" },
  { q: "pillar.switchable.faq.q3", a: "pillar.switchable.faq.a3" },
  { q: "pillar.switchable.faq.q4", a: "pillar.switchable.faq.a4" },
  { q: "pillar.switchable.faq.q5", a: "pillar.switchable.faq.a5" },
];
---
<article class="insight">
  <!-- HERO — asimmetrico, allineato a sinistra -->
  <header class="insight-hero" aria-labelledby="pillar-h1">
    <div class="insight-hero__inner">
      <p class="insight-hero__eyebrow">{t("pillar.switchable.eyebrow")}</p>
      <h1 class="insight-hero__title" id="pillar-h1">{t("pillar.switchable.h1")}</h1>
      <p class="insight-hero__lead">{t("pillar.switchable.lead")}</p>
    </div>
  </header>

  <!-- BLOCCHI CORPO — due colonne (titolo sx / testo dx) -->
  <div class="insight-body">
    {blocks.map((b) => (
      <section class="insight-block">
        <div class="insight-block__inner">
          <div class="insight-block__head">
            <h2 class="insight-block__title">{t(`pillar.switchable.${b.key}.title`)}</h2>
          </div>
          <div class="insight-block__content">
            <p class="insight-block__body">{t(`pillar.switchable.${b.key}.body`)}</p>
            {b.links.length > 0 && (
              <div class="insight-block__links">
                {b.links.map((l) => (
                  <a class="insight-block__link" href={l.href}>
                    {t(l.labelKey)}<span class="insight-block__arrow" aria-hidden="true">&#8594;</span>
                  </a>
                ))}
              </div>
            )}
          </div>
        </div>
      </section>
    ))}
  </div>

  <!-- FAQ -->
  <section class="pillar-faq" aria-labelledby="pillar-faq-title">
    <div class="pillar-faq__inner">
      <h2 class="pillar-faq__title" id="pillar-faq-title">{t("pillar.switchable.faq.title")}</h2>
      <dl class="pillar-faq__list">
        {faqs.map((f) => (
          <div class="pillar-faq__item">
            <dt class="pillar-faq__q">{t(f.q)}</dt>
            <dd class="pillar-faq__a">{t(f.a)}</dd>
          </div>
        ))}
      </dl>
    </div>
  </section>

  <!-- CTA FINALE -->
  <section class="insight-cta" aria-labelledby="pillar-cta-title">
    <div class="insight-cta__inner">
      <h2 class="insight-cta__title" id="pillar-cta-title">{t("pillar.switchable.cta.title")}</h2>
      <p class="insight-cta__body">{t("pillar.switchable.cta.body")}</p>
      <div class="insight-cta__actions">
        <a class="insight-cta__button" href="#contact-eyebrow">{t("pillar.switchable.cta.button")}</a>
        <a class="insight-cta__explore" href={techHref}>
          {t("pillar.switchable.cta.explore")}<span class="insight-block__arrow" aria-hidden="true">&#8594;</span>
        </a>
      </div>
    </div>
  </section>
</article>

<style>
  .insight {
    display: block;
  }

  /* ---------- HERO ---------- */
  .insight-hero {
    padding: calc(var(--space-section-y-lg) + 40px) var(--space-section-x) 32px;
  }
  .insight-hero__inner {
    max-width: var(--container-max);
    margin: 0 auto;
  }
  .insight-hero__eyebrow {
    display: inline-block;
    margin: 0;
    padding: 7px 14px;
    border: 1px solid var(--c-accent-glow);
    border-radius: var(--radius-pill);
    background: rgba(10, 18, 38, 0.6);
    backdrop-filter: blur(8px);
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--c-mist-bright);
  }
  .insight-hero__title {
    margin: 28px 0 0;
    max-width: 22ch;
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 5vw, 3.6rem);
    line-height: 1.08;
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--c-pearl);
  }
  .insight-hero__lead {
    margin: 24px 0 0;
    max-width: 62ch;
    font-size: clamp(1.05rem, 1.6vw, 1.25rem);
    line-height: 1.6;
    color: var(--c-mist);
  }

  /* ---------- BLOCCHI CORPO (due colonne) ---------- */
  .insight-block {
    padding: var(--space-section-y) var(--space-section-x);
  }
  .insight-block__inner {
    max-width: var(--container-max);
    margin: 0 auto;
    display: grid;
    grid-template-columns: minmax(0, 5fr) minmax(0, 7fr);
    column-gap: 64px;
    align-items: start;
  }
  .insight-block__title {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 2.6vw, 2.1rem);
    line-height: 1.22;
    font-weight: 500;
    color: var(--c-pearl);
  }
  .insight-block__body {
    margin: 0;
    font-size: 1rem;
    line-height: 1.7;
    color: var(--c-mist);
  }
  .insight-block__links {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 12px;
    margin-top: 24px;
  }
  .insight-block__link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: 13px;
    letter-spacing: 0.04em;
    color: var(--c-cyan);
    text-decoration: none;
    transition: color 0.2s var(--ease);
  }
  .insight-block__arrow {
    transition: transform 0.2s var(--ease);
  }
  .insight-block__link:hover {
    color: var(--c-accent-bright);
  }
  .insight-block__link:hover .insight-block__arrow {
    transform: translateX(4px);
  }
  .insight-block__link:focus-visible {
    outline: 2px solid var(--c-cyan);
    outline-offset: 4px;
    border-radius: 2px;
  }

  /* ---------- FAQ ---------- */
  .pillar-faq {
    padding: var(--space-section-y) var(--space-section-x);
  }
  .pillar-faq__inner {
    max-width: var(--container-max);
    margin: 0 auto;
  }
  .pillar-faq__title {
    margin: 0 0 32px;
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 2.6vw, 2.1rem);
    line-height: 1.22;
    font-weight: 500;
    color: var(--c-pearl);
  }
  .pillar-faq__list {
    margin: 0;
    display: grid;
    gap: 28px;
  }
  .pillar-faq__item {
    border-top: 1px solid var(--border-hairline);
    padding-top: 24px;
  }
  .pillar-faq__q {
    margin: 0 0 10px;
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 500;
    line-height: 1.3;
    color: var(--c-pearl);
  }
  .pillar-faq__a {
    margin: 0;
    font-size: 1rem;
    line-height: 1.7;
    color: var(--c-mist);
  }

  /* ---------- CTA FINALE ---------- */
  .insight-cta {
    padding: var(--space-section-y) var(--space-section-x) var(--space-section-y-lg);
  }
  .insight-cta__inner {
    max-width: 720px;
    margin: 0 auto;
    text-align: center;
  }
  .insight-cta__title {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(1.6rem, 3vw, 2.4rem);
    line-height: 1.2;
    font-weight: 500;
    color: var(--c-pearl);
  }
  .insight-cta__body {
    margin: 16px auto 0;
    max-width: 52ch;
    color: var(--c-mist);
    line-height: 1.6;
  }
  .insight-cta__actions {
    margin-top: 32px;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 20px 28px;
  }
  .insight-cta__button {
    display: inline-block;
    padding: 14px 32px;
    border: 1px solid var(--c-cyan);
    border-radius: var(--radius-card);
    background: transparent;
    font-family: var(--font-mono);
    font-size: 13px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--c-cyan);
    text-decoration: none;
    transition: background 0.2s var(--ease), color 0.2s var(--ease);
  }
  .insight-cta__button:hover {
    background: var(--c-cyan);
    color: var(--c-void);
  }
  .insight-cta__button:focus-visible {
    outline: 2px solid var(--c-cyan);
    outline-offset: 4px;
  }
  .insight-cta__explore {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: 13px;
    letter-spacing: 0.04em;
    color: var(--c-cyan);
    text-decoration: none;
    transition: color 0.2s var(--ease);
  }
  .insight-cta__explore:hover {
    color: var(--c-accent-bright);
  }
  .insight-cta__explore:hover .insight-block__arrow {
    transform: translateX(4px);
  }
  .insight-cta__explore:focus-visible {
    outline: 2px solid var(--c-cyan);
    outline-offset: 4px;
    border-radius: 2px;
  }

  /* ---------- RESPONSIVE ---------- */
  @media (max-width: 900px) {
    .insight-hero {
      padding: calc(var(--space-section-y) + 24px) 24px var(--space-section-y);
    }
    .insight-block {
      padding: var(--space-section-y) 24px;
    }
    .insight-block__inner {
      grid-template-columns: 1fr;
      row-gap: 20px;
    }
    .pillar-faq {
      padding: var(--space-section-y) 24px;
    }
  }
  @media (max-width: 560px) {
    .insight-hero {
      padding: 72px 24px 56px;
    }
    .insight-block {
      padding: 56px 24px;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .insight-block__link,
    .insight-block__arrow,
    .insight-cta__button,
    .insight-cta__explore {
      transition: none;
    }
  }
</style>
