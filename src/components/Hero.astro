---
import { getLangFromUrl, useTranslations } from "../i18n/utils";
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// Hero. Portato da brixiatech-hero-v1.html.
// Quasi tutto statico; unico JS = parallax leggero di .scene (vedi <script>).
// Possiede la <section.hero> (contesto di posizionamento) + scena + content
// editoriale. Le isole interattive (GlassDemo, Ticker) entrano via <slot />:
// restano figlie di .hero così i loro `position:absolute` risolvono qui.
//
// FIX #1: parallax con rAF throttle, off su touch/schermo stretto/reduced-motion.
// FIX #2: blocco prefers-reduced-motion in fondo (azzera entrance).
// FIX #6: skyline-stub RIMOSSO — la scena diurna ora vive nel pannello GlassDemo;
//         lo sfondo dell'hero è cielo abisso pulito (atmosfera vera in Step C).
---

<section class="hero">
  <!-- Scena background: cielo abisso (skyline-stub rimosso; il pannello porta la scena) -->
  <div class="scene"></div>

  <!-- Contenuto editoriale -->
  <div class="content">
    <div class="eyebrow">{t('hero.eyebrow')}</div>
    <h1 class="headline">
      <span class="headline__line"><span>{t('hero.headline1')}</span></span>
      <span class="headline__line"><span>{t('hero.headline2')}</span></span>
    </h1>
    <p class="subtitle">
      {t('hero.subtitle')}
      <em>{t('hero.subtitleEmphasis')}</em>
    </p>
    <div class="cta-row">
      <a href="#preventivo" class="cta">
        {t('hero.ctaPrimary')}
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <path d="M3 7H11M11 7L7 3M11 7L7 11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
        </svg>
      </a>
      <a href="#b-logic" class="cta-secondary">
        {t('hero.ctaSecondary')}
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <path d="M3 7H11M11 7L7 3M11 7L7 11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
        </svg>
      </a>
    </div>
  </div>

  <!-- Isole interattive (GlassDemo, Ticker) iniettate da index.astro -->
  <slot />
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    overflow: hidden;
    display: flex;
    align-items: center;
  }

  /* =========================================================
     SCENA — cielo abisso (sfondo pulito; lo skyline vive nel pannello)
     ========================================================= */
  .scene {
    position: absolute;
    inset: 0;
    z-index: 1;
    background:
      radial-gradient(ellipse 80% 60% at 70% 40%, rgba(45, 111, 184, 0.22) 0%, transparent 70%),
      radial-gradient(ellipse 60% 40% at 20% 60%, rgba(20, 40, 80, 0.45) 0%, transparent 60%),
      linear-gradient(180deg, #0A1226 0%, #050B1A 70%);
  }

  /* =========================================================
     CONTENT — eyebrow + headline + subtitle + CTA
     ========================================================= */
  .content {
    position: relative;
    z-index: 10;
    padding: 0 8%;
    max-width: 50%;
    pointer-events: none;
  }

  .content > * { pointer-events: auto; }

  .eyebrow {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.22em;
    color: var(--c-cyan);
    margin-bottom: 32px;
    opacity: 0;
    animation: fadeInUp 800ms var(--ease-out) 200ms forwards;
  }

  .eyebrow::before {
    content: '';
    display: inline-block;
    width: 32px;
    height: 1px;
    background: var(--c-cyan);
    vertical-align: middle;
    margin-right: 16px;
  }

  .headline {
    font-family: var(--font-display);
    font-size: clamp(40px, 5.5vw, 76px);
    font-weight: 600;
    letter-spacing: -0.025em;
    line-height: 1;
    margin-bottom: 28px;
  }

  .headline__line {
    display: block;
    overflow: hidden;
  }

  .headline__line span {
    display: inline-block;
    opacity: 0;
    transform: translateY(100%);
    animation: lineUp 1000ms var(--ease-out) forwards;
  }

  .headline__line:nth-child(1) span { animation-delay: 400ms; }
  .headline__line:nth-child(2) span { animation-delay: 600ms; color: var(--c-mist); }

  @keyframes lineUp {
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes fadeInUp {
    to { opacity: 1; transform: translateY(0); }
  }

  .subtitle {
    font-size: 17px;
    line-height: 1.65;
    color: var(--c-mist);
    max-width: 440px;
    margin-bottom: 48px;
    opacity: 0;
    transform: translateY(20px);
    animation: fadeInUp 800ms var(--ease-out) 1000ms forwards;
  }

  .subtitle em {
    font-family: var(--font-serif);
    font-style: italic;
    color: var(--c-copper);
    font-weight: 400;
  }

  .cta-row {
    display: flex;
    gap: 16px;
    align-items: center;
    opacity: 0;
    transform: translateY(20px);
    animation: fadeInUp 800ms var(--ease-out) 1200ms forwards;
  }

  .cta {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 16px 28px;
    background: var(--c-cyan);
    color: var(--c-void);
    text-decoration: none;
    font-size: 14px;
    font-weight: 500;
    border-radius: var(--radius-pill);
    transition: all 300ms var(--ease);
  }

  .cta:hover {
    background: var(--c-pearl);
    transform: translateY(-2px);
  }

  .cta-secondary {
    color: var(--c-pearl);
    font-size: 14px;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 16px 0;
    transition: gap 300ms var(--ease);
  }

  .cta-secondary:hover { gap: 14px; }

  .cta-secondary svg { transition: transform 300ms var(--ease); }
  .cta-secondary:hover svg { transform: translateX(4px); }

  /* =========================================================
     RESPONSIVE
     ========================================================= */
  @media (max-width: 900px) {
    .content { max-width: 100%; padding: 0 24px; }
  }

  /* =========================================================
     FIX #2 — prefers-reduced-motion
     Azzera entrance animations (mostra tutto subito).
     Parallax/auto-cycle vivono nelle isole JS: guard dedicato lì.
     ========================================================= */
  @media (prefers-reduced-motion: reduce) {
    .eyebrow,
    .headline__line span,
    .subtitle,
    .cta-row {
      animation: none;
      opacity: 1;
      transform: none;
    }
  }
</style>

<script>
  // FIX #1 — parallax leggero di .scene, throttlato a 1 write/frame via rAF.
  // Off su reduced-motion, pointer coarse (touch) e schermi stretti.
  const scene = document.querySelector<HTMLElement>(".scene");
  const prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  const coarsePointer = window.matchMedia("(pointer: coarse)").matches;

  if (scene && !prefersReduced && !coarsePointer && window.innerWidth > 900) {
    let ticking = false;
    let mx = 0;
    let my = 0;

    const apply = () => {
      const x = (mx / window.innerWidth - 0.5) * 20;
      const y = (my / window.innerHeight - 0.5) * 10;
      scene.style.transform = `translate(${-x}px, ${-y}px) scale(1.05)`;
      ticking = false;
    };

    window.addEventListener("mousemove", (e) => {
      mx = e.clientX;
      my = e.clientY;
      if (!ticking) {
        ticking = true;
        requestAnimationFrame(apply);
      }
    });
  }
</script>
