---
// InsightsIndex.astro — pagina-indice /insights (hub TOFU). Raccolta di
// approfondimenti pratici per caso d'uso, ciascuno che instrada giù nel funnel.
// Gemello di TecnologieIndex.astro: hero CENTRATO compatto → griglia card → CTA.
// Meccanismo href-opzionale: una voce con `href` è pubblicata (card cliccabile +
// CTA "Leggi l'articolo"); senza `href` non viene renderizzata. Le voci si
// aggiungono all'array `articles[]` quando l'articolo corrispondente è pronto.
// ZERO JS. Token --c-*. Riusa il pattern di TecnologieIndex
// (.tecindex → .insindex).
import { getLangFromUrl, useTranslations } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// Link cross-page lang-aware (stesso pattern di Nav e pagine-prodotto).
const base = lang === "en" ? "/en/" : "/";

// Slug-articolo tradotti (il segmento "insights" è uguale IT/EN, lo slug no).
const techeHref =
  lang === "en"
    ? "/en/insights/covering-protecting-display-cases/"
    : "/insights/coprire-vetri-teche-espositori-vetrine/";

const telecomandoHref =
  lang === "en"
    ? "/en/insights/switchable-glass-remote-control/"
    : "/insights/oscurare-vetri-con-telecomando/";

const privacyHref =
  lang === "en"
    ? "/en/insights/switchable-privacy-glass/"
    : "/insights/vetri-privacy-su-comando/";

const ufficiHref =
  lang === "en"
    ? "/en/insights/glass-partitions-for-offices/"
    : "/insights/pareti-in-vetro-per-ufficio/";

const negozioHref =
  lang === "en"
    ? "/en/insights/switchable-glass-for-shop-windows/"
    : "/insights/oscurare-vetrine-negozio/";

type Article = {
  titleKey: string;
  summaryKey: string;
  href?: string;
  ctaKey?: string;
};

// Solo le voci con `href` vengono renderizzate (= articoli pubblicati).
// Aggiungere una voce con href quando l'articolo corrispondente è pronto.
const articles: Article[] = [
  {
    titleKey: "insights.teche.card.title",
    summaryKey: "insights.teche.card.summary",
    href: techeHref,
    ctaKey: "insights.teche.card.cta",
  },
  {
    titleKey: "insights.telecomando.card.title",
    summaryKey: "insights.telecomando.card.summary",
    href: telecomandoHref,
    ctaKey: "insights.telecomando.card.cta",
  },
  {
    titleKey: "insights.privacy.card.title",
    summaryKey: "insights.privacy.card.summary",
    href: privacyHref,
    ctaKey: "insights.privacy.card.cta",
  },
  {
    titleKey: "insights.uffici.card.title",
    summaryKey: "insights.uffici.card.summary",
    href: ufficiHref,
    ctaKey: "insights.uffici.card.cta",
  },
  {
    titleKey: "insights.negozio.card.title",
    summaryKey: "insights.negozio.card.summary",
    href: negozioHref,
    ctaKey: "insights.negozio.card.cta",
  },
];

const published = articles.filter((a) => a.href && a.ctaKey);
---

<section class="insindex" aria-labelledby="insindex-eyebrow">
  <p class="insindex__eyebrow" id="insindex-eyebrow">{t("insights.eyebrow")}</p>
  <h1 class="insindex__title">{t("insights.title")}</h1>
  <p class="insindex__lead">{t("insights.lead")}</p>

  <div class="insindex__grid">
    {published.map((item) => (
      <article class="insindex__item">
        <h2 class="insindex__name">{t(item.titleKey)}</h2>
        <p class="insindex__desc">{t(item.summaryKey)}</p>
        <a class="insindex__cta" href={item.href}>
          {t(item.ctaKey)}<span class="insindex__arrow" aria-hidden="true">&rarr;</span>
        </a>
      </article>
    ))}
  </div>

  <div class="insindex__foot">
    <a class="insindex__foot-cta" href={`${base}#contact-eyebrow`}>
      {t("insights.cta")}
    </a>
  </div>
</section>

<style>
  /* Hero compatto: padding-top pieno, padding-bottom ridotto così le card entrano
     presto in viewport (pagina di smistamento, non manifesto). Come tecindex. */
  .insindex {
    padding: var(--space-section-y) var(--space-section-x);
  }

  .insindex__eyebrow {
    text-align: center;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    color: var(--c-mist-bright);
    margin: 0 0 24px;
  }

  .insindex__title {
    font-family: var(--font-display);
    color: var(--c-pearl);
    text-align: center;
    font-size: clamp(1.8rem, 3.4vw, 2.6rem);
    line-height: 1.2;
    max-width: 820px;
    margin: 0 auto 24px;
    font-weight: 500;
  }

  .insindex__lead {
    color: var(--c-mist);
    text-align: center;
    max-width: 700px;
    margin: 0 auto 72px;
    line-height: 1.6;
    font-size: 1rem;
  }

  /* Griglia 3 colonne: una riga piena = 3 articoli (pavimento di lancio).
     Con un solo articolo pubblicato la card resta a sinistra a larghezza naturale,
     non stirata sull'intera riga. */
  .insindex__grid {
    max-width: var(--container-max);
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 48px 40px;
  }

  /* Card: hairline superiore, CTA spinta in basso con margin-top:auto così card
     della stessa riga restano allineate con corpi di lunghezza diversa. */
  .insindex__item {
    text-align: left;
    border-top: 1px solid var(--border-hairline);
    padding-top: 24px;
    display: flex;
    flex-direction: column;
  }

  .insindex__name {
    font-family: var(--font-display);
    color: var(--c-pearl);
    font-size: 1.05rem;
    font-weight: 500;
    margin: 0 0 12px;
    line-height: 1.3;
  }

  .insindex__desc {
    color: var(--c-mist);
    font-size: 0.92rem;
    line-height: 1.6;
    margin: 0;
  }

  /* CTA inline: unico elemento interattivo della card → unico punto di cyan.
     Allineata in basso. */
  .insindex__cta {
    margin-top: auto;
    padding-top: 20px;
    align-self: flex-start;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.04em;
    color: var(--c-cyan);
    text-decoration: none;
    transition: gap 200ms var(--ease), color 200ms var(--ease);
  }

  .insindex__cta:hover {
    color: var(--c-cyan);
    gap: 14px;
  }

  .insindex__cta:focus-visible {
    outline: 2px solid var(--c-cyan);
    outline-offset: 3px;
  }

  .insindex__arrow {
    transition: transform 200ms var(--ease);
  }

  .insindex__foot {
    text-align: center;
    margin-top: 72px;
  }

  /* CTA finale outline cyan, coerente con tecindex e Blackout. */
  .insindex__foot-cta {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    letter-spacing: 0.04em;
    color: var(--c-cyan);
    text-decoration: none;
    border: 1px solid var(--c-cyan);
    padding: 14px 28px;
    border-radius: var(--radius-pill);
    transition: background 200ms var(--ease);
  }

  .insindex__foot-cta:hover {
    background: rgba(0, 209, 255, 0.08);
  }

  .insindex__foot-cta:focus-visible {
    outline: 2px solid var(--c-cyan);
    outline-offset: 3px;
  }

  @media (prefers-reduced-motion: reduce) {
    .insindex__cta,
    .insindex__arrow {
      transition: none;
    }
  }

  @media (max-width: 900px) {
    .insindex {
      padding: 56px 24px;
    }
    .insindex__lead {
      margin-bottom: 56px;
    }
    .insindex__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 40px;
    }
  }

  @media (max-width: 560px) {
    .insindex__grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }
  }
</style>
