---
// SmartFilmPdlc.astro — Pagina-prodotto PDLC (template derivato da BlackoutHyperGlass).
// Struttura: hero prodotto (asimmetrico, sinistra) → blocco "what" → blocco "how"
//            → blocco FASCE (Premium | Essential, variante strutturale nuova)
//            → blocco "scale" (B-LOGIC) → CTA finale.
// Blocco fasce: due colonne. Premium = fascia alta, filo copper (signature di
//            fascia, come il blocco "edge" di Blackout). Essential = hairline
//            neutro (essenziale e pulito, MAI svalutata). Su mobile si impilano.
// lang/t ricavati internamente (mai props). Link cross-page lang-aware.
// Token: --c-* / --space-* / --font-* da global.css. ZERO immagini (da aggiungere poi).
import { getLangFromUrl, useTranslations } from "../i18n/utils";
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// Base URL lang-aware per i link cross-page (prefixDefaultLocale: false).
const base = lang === "en" ? "/en/" : "/";
const linkHow = `${base}#how-eyebrow`;
const linkBlogic = `${base}#blogic-eyebrow`;

// Link alla variante scura della stessa famiglia (Blackout Hyper Glass), lang-aware.
const bhgHref =
  lang === "en"
    ? "/en/technologies/blackout-hyper-glass/"
    : "/tecnologie/blackout-hyper-glass/";

// Blocchi corpo "semplici" a due colonne (titolo sx / testo dx).
// "what" porta il rimando a Blackout; "how" e "scale" portano link alla home.
const blocks = [
  { key: "what", link: bhgHref, linkKey: "prod.pdlc.what.link" },
  { key: "how", link: linkHow, linkKey: "prod.pdlc.how.link" },
] as const;
---
<article class="pdlc">
  <!-- HERO PRODOTTO — asimmetrico, allineato a sinistra -->
  <header class="pdlc-hero" aria-labelledby="pdlc-name">
    <div class="pdlc-hero__inner">
      <p class="pdlc-hero__eyebrow">{t("prod.pdlc.eyebrow")}</p>
      <h1 class="pdlc-hero__name" id="pdlc-name">{t("prod.pdlc.name")}</h1>
      <p class="pdlc-hero__tagline">{t("prod.pdlc.tagline")}</p>
    </div>
  </header>

  <!-- BLOCCHI CORPO — due colonne (titolo sx / testo dx) -->
  <div class="pdlc-body">
    {blocks.map((b) => (
      <section class="pdlc-block">
        <div class="pdlc-block__inner">
          <div class="pdlc-block__head">
            <h2 class="pdlc-block__title">{t(`prod.pdlc.${b.key}.title`)}</h2>
          </div>
          <div class="pdlc-block__content">
            <p class="pdlc-block__body">{t(`prod.pdlc.${b.key}.body`)}</p>
            {b.link && (
              <a class="pdlc-block__link" href={b.link}>
                {t(b.linkKey)}<span class="pdlc-block__arrow" aria-hidden="true">&#8594;</span>
              </a>
            )}
          </div>
        </div>
      </section>
    ))}

    <!-- BLOCCO FASCE — Premium | Essential (variante strutturale) -->
    <section class="pdlc-tiers" aria-labelledby="pdlc-tiers-title">
      <div class="pdlc-tiers__inner">
        <h2 class="pdlc-tiers__title" id="pdlc-tiers-title">{t("prod.pdlc.tiers.title")}</h2>
        <div class="pdlc-tiers__grid">
          <div class="pdlc-tier pdlc-tier--premium">
            <p class="pdlc-tier__label">{t("prod.pdlc.premium.label")}</p>
            <p class="pdlc-tier__body">{t("prod.pdlc.premium.body")}</p>
          </div>
          <div class="pdlc-tier pdlc-tier--essential">
            <p class="pdlc-tier__label">{t("prod.pdlc.essential.label")}</p>
            <p class="pdlc-tier__body">{t("prod.pdlc.essential.body")}</p>
          </div>
        </div>
        <p class="pdlc-tiers__note">{t("prod.pdlc.tiers.note")}</p>
      </div>
    </section>

    <!-- BLOCCO SCALE — B-LOGIC -->
    <section class="pdlc-block">
      <div class="pdlc-block__inner">
        <div class="pdlc-block__head">
          <h2 class="pdlc-block__title">{t("prod.pdlc.scale.title")}</h2>
        </div>
        <div class="pdlc-block__content">
          <p class="pdlc-block__body">{t("prod.pdlc.scale.body")}</p>
          <a class="pdlc-block__link" href={linkBlogic}>
            {t("prod.pdlc.scale.link")}<span class="pdlc-block__arrow" aria-hidden="true">&#8594;</span>
          </a>
        </div>
      </div>
    </section>
  </div>

  <!-- CTA FINALE -->
  <section class="pdlc-cta" aria-labelledby="pdlc-cta-title">
    <div class="pdlc-cta__inner">
      <h2 class="pdlc-cta__title" id="pdlc-cta-title">{t("prod.pdlc.cta.title")}</h2>
      <p class="pdlc-cta__body">{t("prod.pdlc.cta.body")}</p>
      <a class="pdlc-cta__button" href="#contact-eyebrow" data-umami-event="cta-scroll">{t("prod.pdlc.cta.button")}</a>
    </div>
  </section>
</article>

<style>
  .pdlc {
    display: block;
  }

  /* ---------- HERO PRODOTTO ---------- */
  .pdlc-hero {
    padding: calc(var(--space-section-y-lg) + 40px) var(--space-section-x) 32px;
  }
  .pdlc-hero__inner {
    max-width: var(--container-max);
    margin: 0 auto;
  }
  .pdlc-hero__eyebrow {
    display: inline-block;
    margin: 0;
    padding: 7px 14px;
    border: 1px solid var(--c-accent-glow);
    border-radius: var(--radius-pill);
    background: rgba(10, 18, 38, 0.6);
    backdrop-filter: blur(8px);
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--c-mist-bright);
  }
  .pdlc-hero__name {
    margin: 28px 0 0;
    max-width: 18ch;
    font-family: var(--font-display);
    font-size: clamp(2.6rem, 6vw, 4.6rem);
    line-height: 1.04;
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--c-pearl);
  }
  .pdlc-hero__tagline {
    margin: 24px 0 0;
    max-width: 46ch;
    font-size: clamp(1.05rem, 1.6vw, 1.3rem);
    line-height: 1.5;
    color: var(--c-mist);
  }

  /* ---------- BLOCCHI CORPO (due colonne) ---------- */
  .pdlc-block {
    padding: var(--space-section-y) var(--space-section-x);
  }
  .pdlc-block__inner {
    max-width: var(--container-max);
    margin: 0 auto;
    display: grid;
    grid-template-columns: minmax(0, 5fr) minmax(0, 7fr);
    column-gap: 64px;
    align-items: start;
  }
  .pdlc-block__title {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 2.6vw, 2.1rem);
    line-height: 1.22;
    font-weight: 500;
    color: var(--c-pearl);
  }
  .pdlc-block__body {
    margin: 0;
    font-size: 1rem;
    line-height: 1.7;
    color: var(--c-mist);
  }
  .pdlc-block__link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-top: 24px;
    font-family: var(--font-mono);
    font-size: 13px;
    letter-spacing: 0.04em;
    color: var(--c-cyan);
    text-decoration: none;
    transition: color 0.2s var(--ease);
  }
  .pdlc-block__arrow {
    transition: transform 0.2s var(--ease);
  }
  .pdlc-block__link:hover {
    color: var(--c-accent-bright);
  }
  .pdlc-block__link:hover .pdlc-block__arrow {
    transform: translateX(4px);
  }
  .pdlc-block__link:focus-visible {
    outline: 2px solid var(--c-cyan);
    outline-offset: 4px;
    border-radius: 2px;
  }

  /* ---------- BLOCCO FASCE (Premium | Essential) ---------- */
  .pdlc-tiers {
    padding: var(--space-section-y) var(--space-section-x);
  }
  .pdlc-tiers__inner {
    max-width: var(--container-max);
    margin: 0 auto;
  }
  .pdlc-tiers__title {
    margin: 0 0 40px;
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 2.6vw, 2.1rem);
    line-height: 1.22;
    font-weight: 500;
    color: var(--c-pearl);
  }
  .pdlc-tiers__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 32px;
  }
  .pdlc-tier {
    box-sizing: border-box;
    background: var(--c-onyx);
    border: 1px solid var(--border-hairline);
    border-radius: var(--radius-card);
    padding: 40px;
    display: flex;
    flex-direction: column;
  }
  /* Premium: fascia alta → filo copper (signature di fascia, come "edge" Blackout). */
  .pdlc-tier--premium {
    border-left: 2px solid var(--c-copper);
  }
  .pdlc-tier__label {
    margin: 0 0 16px;
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--c-mist-bright);
  }
  .pdlc-tier--premium .pdlc-tier__label {
    color: var(--c-copper);
  }
  .pdlc-tier__body {
    margin: 0;
    font-size: 1rem;
    line-height: 1.7;
    color: var(--c-mist);
  }
  .pdlc-tiers__note {
    margin: 32px 0 0;
    max-width: 70ch;
    font-size: 0.92rem;
    line-height: 1.6;
    color: var(--c-mist-bright);
  }

  /* ---------- CTA FINALE ---------- */
  .pdlc-cta {
    padding: var(--space-section-y) var(--space-section-x) var(--space-section-y-lg);
  }
  .pdlc-cta__inner {
    max-width: 720px;
    margin: 0 auto;
    text-align: center;
  }
  .pdlc-cta__title {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(1.6rem, 3vw, 2.4rem);
    line-height: 1.2;
    font-weight: 500;
    color: var(--c-pearl);
  }
  .pdlc-cta__body {
    margin: 16px auto 0;
    max-width: 52ch;
    color: var(--c-mist);
    line-height: 1.6;
  }
  .pdlc-cta__button {
    display: inline-block;
    margin-top: 32px;
    padding: 14px 32px;
    border: 1px solid var(--c-cyan);
    border-radius: var(--radius-card);
    background: transparent;
    font-family: var(--font-mono);
    font-size: 13px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--c-cyan);
    text-decoration: none;
    transition: background 0.2s var(--ease), color 0.2s var(--ease);
  }
  .pdlc-cta__button:hover {
    background: var(--c-cyan);
    color: var(--c-void);
  }
  .pdlc-cta__button:focus-visible {
    outline: 2px solid var(--c-cyan);
    outline-offset: 4px;
  }

  /* ---------- RESPONSIVE ---------- */
  @media (max-width: 900px) {
    .pdlc-hero {
      padding: calc(var(--space-section-y) + 24px) 24px var(--space-section-y);
    }
    .pdlc-block {
      padding: var(--space-section-y) 24px;
    }
    .pdlc-block__inner {
      grid-template-columns: 1fr;
      row-gap: 20px;
    }
    .pdlc-tiers {
      padding: var(--space-section-y) 24px;
    }
    .pdlc-tiers__grid {
      grid-template-columns: 1fr;
      gap: 24px;
    }
    .pdlc-tier {
      padding: 32px 24px;
    }
  }
  @media (max-width: 560px) {
    .pdlc-hero {
      padding: 72px 24px 56px;
    }
    .pdlc-block {
      padding: 56px 24px;
    }
    .pdlc-tiers {
      padding: 56px 24px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .pdlc-block__link,
    .pdlc-block__arrow,
    .pdlc-cta__button {
      transition: none;
    }
  }
</style>
