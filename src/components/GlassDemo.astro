---
// Isola interattiva PDLC. Portata da brixiatech-hero-v1.html.
// JS via <script> nativo Astro (modulo bundlato, defer) — niente framework
// island: scelta più leggera per un toggle. È figlia di .hero (slot in Hero).
//
// FIX #3: auto-cycle CANCELLABILE — il primo click utente azzera i timer
//         residui, così non confligge col toggle manuale.
// FIX #2: sotto prefers-reduced-motion l'auto-cycle NON parte e il count-up
//         salta al valore finale (il click manuale resta disponibile).
---

<div class="glass-stage">
  <button
    class="glass"
    id="glass"
    type="button"
    data-state="off"
    aria-label="Attiva/disattiva il vetro PDLC"
    aria-pressed="false"
  >
    <div class="glass-reflection"></div>
    <div class="glass-indicator">
      <span class="glass-indicator__dot"></span>
      <span id="state-label">PDLC · OFF · PRIVACY</span>
    </div>
    <div class="glass-readout">
      TRANSMITTANCE<span class="glass-readout__value" id="transmittance">2%</span>
    </div>
  </button>
</div>

<!-- Hint interazione -->
<div class="toggle-hint">
  <span>CLICK GLASS TO ACTIVATE</span>
</div>

<style>
  .glass-stage {
    position: absolute;
    inset: 0;
    z-index: 5;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    padding: 0 8% 0 0;
    pointer-events: none;
  }

  .glass {
    /* reset stili button di default */
    appearance: none;
    -webkit-appearance: none;
    margin: 0;
    padding: 0;
    font: inherit;
    color: inherit;
    text-align: inherit;

    width: 42%;
    height: 78%;
    max-width: 560px;
    position: relative;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 2px;
    overflow: hidden;
    transition: all 1200ms var(--ease);
    pointer-events: auto;
    cursor: pointer;
  }

  .glass:focus-visible {
    outline: 2px solid var(--c-cyan);
    outline-offset: 3px;
  }

  /* Frame del vetro (cornice sottile, stile architettonico) */
  .glass::before {
    content: '';
    position: absolute;
    inset: 0;
    border: 1px solid rgba(255, 255, 255, 0.04);
    pointer-events: none;
    z-index: 3;
  }

  /* PDLC OFF — vetro opaco/privacy */
  .glass[data-state="off"] {
    background: rgba(245, 245, 247, 0.88);
    backdrop-filter: blur(30px) saturate(0.4);
    -webkit-backdrop-filter: blur(30px) saturate(0.4);
  }

  /* PDLC ON — vetro trasparente */
  .glass[data-state="on"] {
    background: rgba(255, 255, 255, 0.02);
    backdrop-filter: blur(0px) saturate(1);
    -webkit-backdrop-filter: blur(0px) saturate(1);
    border-color: rgba(0, 212, 255, 0.15);
  }

  .glass-reflection {
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 100%;
    background: linear-gradient(
      135deg,
      rgba(255, 255, 255, 0.06) 0%,
      transparent 30%,
      transparent 70%,
      rgba(255, 255, 255, 0.02) 100%
    );
    pointer-events: none;
    z-index: 2;
  }

  .glass-indicator {
    position: absolute;
    top: 16px;
    right: 16px;
    display: flex;
    align-items: center;
    gap: 8px;
    z-index: 4;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    color: var(--c-cyan);
    transition: color 600ms var(--ease);
  }

  .glass[data-state="off"] .glass-indicator {
    color: var(--c-mist);
  }

  .glass-indicator__dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: currentColor;
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.4; transform: scale(0.8); }
  }

  .glass-readout {
    position: absolute;
    bottom: 16px;
    left: 16px;
    z-index: 4;
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--c-mist);
    letter-spacing: 0.08em;
  }

  .glass-readout__value {
    color: var(--c-pearl);
    margin-left: 8px;
  }

  /* Hint interazione */
  .toggle-hint {
    position: absolute;
    top: 50%;
    right: 8%;
    transform: translate(0, -50%) translateX(-100%);
    z-index: 15;
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--c-mist);
    letter-spacing: 0.12em;
    opacity: 0;
    animation: fadeInUp 800ms var(--ease-out) 2000ms forwards;
  }

  .toggle-hint span {
    display: block;
    padding: 6px 12px;
    border: 1px solid rgba(245, 245, 247, 0.15);
    border-radius: 4px;
    background: rgba(5, 5, 7, 0.6);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  @keyframes fadeInUp {
    to { opacity: 1; transform: translate(0, -50%) translateX(0); }
  }

  @media (max-width: 900px) {
    .glass-stage { display: none; }
    .toggle-hint { display: none; }
  }

  /* FIX #2 — reduced-motion: ferma pulse + mostra subito l'hint */
  @media (prefers-reduced-motion: reduce) {
    .glass-indicator__dot { animation: none; }
    .toggle-hint {
      animation: none;
      opacity: 1;
      transform: translate(0, -50%) translateX(0);
    }
  }
</style>

<script>
  const glass = document.getElementById("glass");
  const stateLabel = document.getElementById("state-label");
  const transmittance = document.getElementById("transmittance");

  if (glass && stateLabel && transmittance) {
    const prefersReduced = window.matchMedia(
      "(prefers-reduced-motion: reduce)"
    ).matches;

    function animateTransmittance(from: number, to: number) {
      // Reduced-motion: niente count-up, salta al valore finale.
      if (prefersReduced) {
        transmittance!.textContent = to + "%";
        return;
      }
      const duration = 1100;
      const start = performance.now();
      function step(now: number) {
        const t = Math.min((now - start) / duration, 1);
        const eased = 1 - Math.pow(1 - t, 3); // ease-out cubic
        transmittance!.textContent = Math.round(from + (to - from) * eased) + "%";
        if (t < 1) requestAnimationFrame(step);
      }
      requestAnimationFrame(step);
    }

    function toggleGlass() {
      const next = glass!.dataset.state === "off" ? "on" : "off";
      glass!.dataset.state = next;
      glass!.setAttribute("aria-pressed", String(next === "on"));
      if (next === "on") {
        animateTransmittance(2, 87);
        stateLabel!.textContent = "PDLC · ON · CLEAR";
      } else {
        animateTransmittance(87, 2);
        stateLabel!.textContent = "PDLC · OFF · PRIVACY";
      }
    }

    // FIX #3 — auto-cycle interrompibile al primo input utente.
    let autoTimers: number[] = [];
    const clearAutoCycle = () => {
      autoTimers.forEach(clearTimeout);
      autoTimers = [];
    };

    glass.addEventListener("click", () => {
      clearAutoCycle();
      toggleGlass();
    });

    // Auto-cycle solo se l'utente non chiede reduced-motion.
    if (!prefersReduced) {
      autoTimers.push(window.setTimeout(toggleGlass, 3500));
      autoTimers.push(window.setTimeout(toggleGlass, 7000));
    }
  }
</script>
