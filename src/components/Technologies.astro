---
// Technologies.astro — sezione #5 homepage, portfolio tecnologie switchable.
// 5 tecnologie in 2 famiglie (privacy: pdlc/pnlc · luce-calore: spd/ec/dlc), no card.
// ZERO JS. Token --c-*. Reduced-motion + responsive coerenti con ProblemSection.
// Nessuna icona. i18n via tech.* keys. Gerarchia: h2 titolo / h3 famiglia / h4 tecnologia.

import { getLangFromUrl, useTranslations } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const bhgHref =
  lang === "en"
    ? "/en/technologies/blackout-hyper-glass"
    : "/tecnologie/blackout-hyper-glass";

const pdlcHref =
  lang === "en"
    ? "/en/technologies/smart-film-pdlc"
    : "/tecnologie/smart-film-pdlc";

const pnlcHref =
  lang === "en"
    ? "/en/technologies/smart-film-pnlc"
    : "/tecnologie/smart-film-pnlc";

const spdHref =
  lang === "en"
    ? "/en/technologies/spd-smart-glass"
    : "/tecnologie/spd-smart-glass";

const ecHref =
  lang === "en"
    ? "/en/technologies/ec-smart-glass"
    : "/tecnologie/ec-smart-glass";

type Tech = { titleKey: string; bodyKey: string; href?: string; ctaKey?: string };

const family1: Tech[] = [
  { titleKey: 'tech.pdlc.title', bodyKey: 'tech.pdlc.body', href: pdlcHref, ctaKey: 'techindex.pdlc.cta' },
  { titleKey: 'tech.pnlc.title', bodyKey: 'tech.pnlc.body', href: pnlcHref, ctaKey: 'techindex.pnlc.cta' },
];

const family2: Tech[] = [
  { titleKey: 'tech.spd.title', bodyKey: 'tech.spd.body', href: spdHref, ctaKey: 'techindex.spd.cta' },
  { titleKey: 'tech.ec.title', bodyKey: 'tech.ec.body', href: ecHref, ctaKey: 'techindex.ec.cta' },
  { titleKey: 'tech.dlc.title', bodyKey: 'tech.dlc.body', href: bhgHref, ctaKey: 'techindex.dlc.cta' },
];
---

<section class="tech" aria-labelledby="tech-eyebrow">
  <p class="tech__eyebrow" id="tech-eyebrow">{t('tech.eyebrow')}</p>
  <h2 class="tech__title">{t('tech.title')}</h2>
  <p class="tech__lead">{t('tech.lead')}</p>

  <h3 class="tech__family">{t('tech.family1.label')}</h3>
  <div class="tech__grid tech__grid--2">
    {family1.map((item) => (
      <article class="tech__item">
        <h4 class="tech__name">{t(item.titleKey)}</h4>
        <p class="tech__desc">{t(item.bodyKey)}</p>
        {item.href && item.ctaKey && (
          <a class="tech__cta" href={item.href}>
            {t(item.ctaKey)}<span class="tech__arrow" aria-hidden="true">&rarr;</span>
          </a>
        )}
      </article>
    ))}
  </div>

  <h3 class="tech__family tech__family--2">{t('tech.family2.label')}</h3>
  <div class="tech__grid tech__grid--3">
    {family2.map((item) => (
      <article class="tech__item">
        <h4 class="tech__name">{t(item.titleKey)}</h4>
        <p class="tech__desc">{t(item.bodyKey)}</p>
        {item.href && item.ctaKey && (
          <a class="tech__cta" href={item.href}>
            {t(item.ctaKey)}<span class="tech__arrow" aria-hidden="true">&rarr;</span>
          </a>
        )}
      </article>
    ))}
  </div>

  <p class="tech__channel">{t('tech.channel')}</p>
</section>

<style>
  .tech {
    padding: var(--space-section-y) var(--space-section-x);
  }

  .tech__eyebrow {
    text-align: center;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    color: var(--c-mist-bright);
    margin: 0 0 24px;
  }

  .tech__title {
    font-family: var(--font-display);
    color: var(--c-pearl);
    text-align: center;
    font-size: clamp(1.6rem, 3vw, 2.4rem);
    line-height: 1.2;
    max-width: 800px;
    margin: 0 auto 24px;
    font-weight: 500;
  }

  .tech__lead {
    color: var(--c-mist);
    text-align: center;
    max-width: 680px;
    margin: 0 auto 64px;
    line-height: 1.6;
    font-size: 1rem;
  }

  .tech__family {
    font-family: var(--font-display);
    color: var(--c-mist-bright);
    text-align: center;
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    max-width: var(--container-max);
    margin: 0 auto 32px;
  }

  .tech__family--2 {
    margin-top: 72px;
  }

  .tech__grid {
    max-width: var(--container-max);
    margin: 0 auto;
    display: grid;
    gap: 48px 40px;
  }

  .tech__grid--2 {
    grid-template-columns: repeat(2, 1fr);
  }

  .tech__grid--4 {
    grid-template-columns: repeat(4, 1fr);
  }

  /* 3 colonne: family2 senza CLC (rimossa fino a nuovo ordine). --4 tenuta per il ritorno. */
  .tech__grid--3 {
    grid-template-columns: repeat(3, 1fr);
  }

  .tech__item {
    text-align: left;
    border-top: 1px solid var(--border-hairline);
    padding-top: 24px;
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .tech__name {
    font-family: var(--font-display);
    color: var(--c-pearl);
    font-size: 1.05rem;
    font-weight: 500;
    margin: 0 0 12px;
    line-height: 1.3;
  }

  .tech__desc {
    color: var(--c-mist);
    font-size: 0.92rem;
    line-height: 1.6;
    margin: 0;
  }

  .tech__cta {
    margin-top: auto;
    padding-top: 16px;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.04em;
    color: var(--c-cyan);
    text-decoration: none;
    transition: gap 200ms var(--ease), color 200ms var(--ease);
  }

  .tech__cta:hover {
    gap: 14px;
  }

  .tech__cta:focus-visible {
    outline: 2px solid var(--c-cyan);
    outline-offset: 3px;
  }

  .tech__arrow {
    transition: transform 200ms var(--ease);
  }

  @media (prefers-reduced-motion: reduce) {
    .tech__cta,
    .tech__arrow {
      transition: none;
    }
  }

  .tech__channel {
    color: var(--c-mist-bright);
    text-align: center;
    max-width: 720px;
    margin: 64px auto 0;
    line-height: 1.6;
    font-size: 0.95rem;
    font-style: italic;
  }

  /* Nessuna transition/animazione in questo componente → nulla da neutralizzare.
     Blocco mantenuto per coerenza con ProblemSection (reduced-motion ready). */
  @media (prefers-reduced-motion: reduce) {
    /* no-op */
  }

  @media (max-width: 900px) {
    .tech {
      padding: 56px 24px;
    }
    .tech__lead {
      margin-bottom: 48px;
    }
    .tech__grid {
      gap: 40px;
    }
    .tech__grid--4,
    .tech__grid--3 {
      grid-template-columns: repeat(2, 1fr);
    }
    .tech__family--2 {
      margin-top: 56px;
    }
  }

  @media (max-width: 560px) {
    .tech__grid--2,
    .tech__grid--3,
    .tech__grid--4 {
      grid-template-columns: 1fr;
      gap: 32px;
    }
  }
</style>
