---
// SmartGlassEc.astro — Pagina-prodotto Smart Glass EC (vetro elettrocromico, controllo solare passivo).
// Struttura: hero prodotto (asimmetrico, sinistra) → 4 blocchi corpo a due colonne
//            (titolo sx / testo dx) → CTA finale. Derivato da SmartGlassSpd.astro.
// Il blocco "edge" (distintivo) ha fondo --c-onyx + bordo copper: signature = la
//            bistabilità, l’unico vetro della gamma che mantiene lo stato senza energia.
// Differenza dal template SPD: il blocco "how" NON ha link (il meccanismo EC a
//            reazione elettrochimica è una categoria a sé, distinta dallo switchable).
//            Il blocco "what" linka alla pagina SPD (dimming continuo) → const spdHref.
// lang/t ricavati internamente (mai props). Token: --c-* / --space-* / --font-* da global.css.
import { getLangFromUrl, useTranslations } from "../i18n/utils";
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// Base URL lang-aware per i link cross-page verso la home (prefixDefaultLocale: false).
const base = lang === "en" ? "/en/" : "/";
const linkBlogic = `${base}#blogic-eyebrow`;

// Link a pagina-prodotto: i segmenti di path sono tradotti → const dedicato lang-aware.
const spdHref = lang === "en"
  ? "/en/technologies/spd-smart-glass/"
  : "/tecnologie/spd-smart-glass/";

// Blocchi corpo a due colonne. "edge" è il blocco distintivo (variante visiva).
// "how" senza link: il meccanismo EC (reazione elettrochimica) è categoria a sé.
const blocks = [
  { key: "what", variant: "plain", link: spdHref, linkKey: "prod.ec.what.link" },
  { key: "edge", variant: "feature", link: null },
  { key: "how", variant: "plain", link: null },
  { key: "scale", variant: "plain", link: linkBlogic, linkKey: "prod.ec.scale.link" },
] as const;
---
<article class="ec">
  <!-- HERO PRODOTTO — asimmetrico, allineato a sinistra -->
  <header class="ec-hero" aria-labelledby="ec-name">
    <div class="ec-hero__inner">
      <p class="ec-hero__eyebrow">{t("prod.ec.eyebrow")}</p>
      <h1 class="ec-hero__name" id="ec-name">{t("prod.ec.name")}</h1>
      <p class="ec-hero__tagline">{t("prod.ec.tagline")}</p>
    </div>
  </header>

  <!-- BLOCCHI CORPO — due colonne (titolo sx / testo dx) -->
  <div class="ec-body">
    {blocks.map((b) => (
      <section class={`ec-block ec-block--${b.variant}`}>
        <div class="ec-block__inner">
          <div class="ec-block__head">
            <h2 class="ec-block__title">{t(`prod.ec.${b.key}.title`)}</h2>
          </div>
          <div class="ec-block__content">
            <p class="ec-block__body">{t(`prod.ec.${b.key}.body`)}</p>
            {b.link && (
              <a class="ec-block__link" href={b.link}>
                {t(b.linkKey)}<span class="ec-block__arrow" aria-hidden="true">&#8594;</span>
              </a>
            )}
          </div>
        </div>
      </section>
    ))}
  </div>

  <!-- CTA FINALE -->
  <section class="ec-cta" aria-labelledby="ec-cta-title">
    <div class="ec-cta__inner">
      <h2 class="ec-cta__title" id="ec-cta-title">{t("prod.ec.cta.title")}</h2>
      <p class="ec-cta__body">{t("prod.ec.cta.body")}</p>
      <a class="ec-cta__button" href="#contact-eyebrow" data-umami-event="cta-scroll">{t("prod.ec.cta.button")}</a>
    </div>
  </section>
</article>

<style>
  .ec {
    display: block;
  }

  /* ---------- HERO PRODOTTO ---------- */
  .ec-hero {
    padding: calc(var(--space-section-y-lg) + 40px) var(--space-section-x) 32px;
  }
  .ec-hero__inner {
    max-width: var(--container-max);
    margin: 0 auto;
  }
  .ec-hero__eyebrow {
    display: inline-block;
    margin: 0;
    padding: 7px 14px;
    border: 1px solid var(--c-accent-glow);
    border-radius: var(--radius-pill);
    background: rgba(10, 18, 38, 0.6);
    backdrop-filter: blur(8px);
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--c-mist-bright);
  }
  .ec-hero__name {
    margin: 28px 0 0;
    max-width: 16ch;
    font-family: var(--font-display);
    font-size: clamp(2.6rem, 6vw, 4.6rem);
    line-height: 1.04;
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--c-pearl);
  }
  .ec-hero__tagline {
    margin: 24px 0 0;
    max-width: 46ch;
    font-size: clamp(1.05rem, 1.6vw, 1.3rem);
    line-height: 1.5;
    color: var(--c-mist);
  }

  /* ---------- BLOCCHI CORPO (due colonne) ---------- */
  .ec-block {
    padding: var(--space-section-y) var(--space-section-x);
  }
  .ec-block__inner {
    max-width: var(--container-max);
    margin: 0 auto;
    display: grid;
    grid-template-columns: minmax(0, 5fr) minmax(0, 7fr);
    column-gap: 64px;
    align-items: start;
  }
  .ec-block__title {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 2.6vw, 2.1rem);
    line-height: 1.22;
    font-weight: 500;
    color: var(--c-pearl);
  }
  .ec-block__body {
    margin: 0;
    font-size: 1rem;
    line-height: 1.7;
    color: var(--c-mist);
  }
  .ec-block__link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-top: 24px;
    font-family: var(--font-mono);
    font-size: 13px;
    letter-spacing: 0.04em;
    color: var(--c-cyan);
    text-decoration: none;
    transition: color 0.2s var(--ease);
  }
  .ec-block__arrow {
    transition: transform 0.2s var(--ease);
  }
  .ec-block__link:hover {
    color: var(--c-accent-bright);
  }
  .ec-block__link:hover .ec-block__arrow {
    transform: translateX(4px);
  }
  .ec-block__link:focus-visible {
    outline: 2px solid var(--c-cyan);
    outline-offset: 4px;
    border-radius: 2px;
  }

  /* ---------- SIGNATURE: blocco distintivo "edge" ---------- */
  /* La bistabilità: fondo più profondo, filo rame. */
  .ec-block--feature .ec-block__inner {
    box-sizing: border-box;
    background: var(--c-onyx);
    border: 1px solid var(--border-hairline);
    border-left: 2px solid var(--c-copper);
    border-radius: var(--radius-card);
    padding: 48px;
    column-gap: 56px;
  }
  .ec-block--feature .ec-block__title {
    color: var(--c-pearl);
  }

  /* ---------- CTA FINALE ---------- */
  .ec-cta {
    padding: var(--space-section-y) var(--space-section-x) var(--space-section-y-lg);
  }
  .ec-cta__inner {
    max-width: 720px;
    margin: 0 auto;
    text-align: center;
  }
  .ec-cta__title {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(1.6rem, 3vw, 2.4rem);
    line-height: 1.2;
    font-weight: 500;
    color: var(--c-pearl);
  }
  .ec-cta__body {
    margin: 16px auto 0;
    max-width: 52ch;
    color: var(--c-mist);
    line-height: 1.6;
  }
  .ec-cta__button {
    display: inline-block;
    margin-top: 32px;
    padding: 14px 32px;
    border: 1px solid var(--c-cyan);
    border-radius: var(--radius-card);
    background: transparent;
    font-family: var(--font-mono);
    font-size: 13px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--c-cyan);
    text-decoration: none;
    transition: background 0.2s var(--ease), color 0.2s var(--ease);
  }
  .ec-cta__button:hover {
    background: var(--c-cyan);
    color: var(--c-void);
  }
  .ec-cta__button:focus-visible {
    outline: 2px solid var(--c-cyan);
    outline-offset: 4px;
  }

  /* ---------- RESPONSIVE ---------- */
  @media (max-width: 900px) {
    .ec-hero {
      padding: calc(var(--space-section-y) + 24px) 24px var(--space-section-y);
    }
    .ec-block {
      padding: var(--space-section-y) 24px;
    }
    .ec-block__inner {
      grid-template-columns: 1fr;
      row-gap: 20px;
    }
    .ec-block--feature .ec-block__inner {
      padding: 32px 24px;
    }
  }
  @media (max-width: 560px) {
    .ec-hero {
      padding: 72px 24px 56px;
    }
    .ec-block {
      padding: 56px 24px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .ec-block__link,
    .ec-block__arrow,
    .ec-cta__button {
      transition: none;
    }
  }
</style>
